{
  "name": "humanity-llc",
  "private": true,
  "description": "Humanity Commons  -  static site (Pages) + reference resolver (Worker)",
  "scripts": {
    "build": "node -e \"const fs=require('fs'); fs.accessSync('site/index.html'); fs.accessSync('site/404.html'); console.log('Static site ready: site/')\"",
    "deploy": "wrangler pages deploy site --project-name=humanity-llc",
    "pages:deploy": "wrangler pages deploy site --project-name=humanity-llc",
    "pages:dev": "wrangler pages dev site",
    "worker:dev": "wrangler dev --config worker/wrangler.toml",
    "worker:bundle-scan": "tsx worker/scripts/bundle-scan-assets.ts",
    "worker:deploy": "npm run worker:bundle-scan && wrangler deploy --config worker/wrangler.toml",
    "worker:d1:create": "wrangler d1 create humanity-resolver --config worker/wrangler.toml",
    "worker:migrate:local": "wrangler d1 migrations apply humanity-resolver --local --config worker/wrangler.toml",
    "worker:migrate:remote": "wrangler d1 migrations apply humanity-resolver --remote --config worker/wrangler.toml",
    "worker:fixtures": "tsx worker/scripts/generate-fixtures.ts",
    "worker:test": "vitest run",
    "worker:test:device": "vitest run worker/tests/device",
    "worker:test:card-disabled-since-visit": "vitest run worker/tests/wallet-network.test.ts worker/tests/device-wallet-network-confirmed.test.ts worker/tests/device-wallet-network-truth.test.ts worker/tests/card-disabled-since-visit-regression.test.ts worker/tests/card-disabled-since-visit-approaches.test.ts worker/tests/device-hub-frontend-pipeline.test.ts worker/tests/device-hub-search-core.test.ts",
    "worker:test:steward-billing": "vitest run worker/tests/billing-lifecycle.test.ts worker/tests/billing-webhook.test.ts worker/tests/stripe-webhook-verify.test.ts worker/tests/steward-hosted.test.ts",
    "worker:test:steward-entitlements": "vitest run worker/tests/device-steward-entitlements-core.test.ts worker/tests/device-steward-entitlements.test.ts worker/tests/device-live-control-poll-budget-core.test.ts worker/tests/device-live-control-poll-scheduler.test.ts worker/tests/device-wallet-scale-core.test.ts worker/tests/device-live-control-sw-core.test.ts worker/tests/device-steward-quota-core.test.ts",
    "worker:test:steward-push": "vitest run worker/tests/device-steward-push-core.test.ts worker/tests/steward-push-sse.test.ts worker/tests/steward-push-notify.test.ts worker/tests/device-live-control-sw-core.test.ts",
    "worker:test:steward-ops": "vitest run worker/tests/steward-ops.test.ts worker/tests/steward-ops-thresholds.test.ts",
    "worker:test:steward-hosted": "npm run worker:test:steward-entitlements && npm run worker:test:steward-push && npm run worker:test:steward-billing && npm run worker:test:steward-ops",
    "worker:check-steward-ops": "tsx worker/scripts/check-steward-ops-thresholds.ts",
    "e2e:hosted-tier": "playwright test e2e/hosted-tier-budget.spec.ts",
    "e2e:hosted-tier-push": "playwright test e2e/hosted-tier-push.spec.ts",
    "e2e:steward-hosted": "npm run e2e:hosted-tier && npm run e2e:hosted-tier-push",
    "worker:test:ui-color-scheme": "vitest run worker/tests/ui-color-scheme-popover-guard.test.ts",
    "worker:test:created-setup-hash": "vitest run worker/tests/created-setup-hash.test.ts",
    "worker:test:scan-live-check-arrive": "vitest run worker/tests/scan-live-check-arrive-core.test.ts",
    "worker:test:scan-actor-band": "vitest run worker/tests/scan-actor-band-core.test.ts",
    "worker:test:qr-branding": "vitest run worker/tests/scan-qr-branding.test.ts worker/tests/qr-render-contract.test.ts worker/tests/qr-print-sticker.test.ts",
    "worker:test:scan-page-dot": "vitest run worker/tests/scan-page-dot-core.test.ts worker/tests/scan-page-dot-glance-core.test.ts worker/tests/scan-page-dot-contract.test.ts worker/tests/device-dot-state.test.ts",
    "worker:test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:card-disabled-since-visit": "playwright test e2e/device-os-wallet.spec.ts e2e/device-inbox.spec.ts",
    "e2e:created-control": "playwright test e2e/created-control.spec.ts",
    "e2e:install": "playwright install chromium webkit",
    "e2e:safari": "playwright test e2e/safari-shell-scroll.spec.ts e2e/scan-cross-tab-banner-webkit.spec.ts",
    "e2e:scan-page-dot": "playwright test e2e/scan-page-dot.spec.ts",
    "e2e:scan-hero-visual": "playwright test e2e/scan-hero-visual.spec.ts",
    "e2e:scan-hero-visual:webkit": "playwright test e2e/scan-hero-visual.spec.ts --project=webkit --project=iphone-13-pro",
    "e2e:shell-emphasis-card": "playwright test e2e/shell-emphasis-card-delivery.spec.ts",
    "e2e:keys-custody": "playwright test e2e/device-os-wallet.spec.ts -g \"keys custody\" e2e/keys-custody-emphasis-webkit.spec.ts",
    "e2e:keys-custody:webkit": "playwright test e2e/keys-custody-emphasis-webkit.spec.ts --project=webkit --project=iphone-13-pro",
    "worker:test:keys-custody": "vitest run worker/tests/device-keys-custody-html.test.ts worker/tests/device-keys-custody-core.test.ts worker/tests/device-emphasis-card-html.test.ts",
    "site:generate-scan-e2e-fixture": "tsx worker/scripts/generate-scan-e2e-fixture.ts",
    "site:vendor-qr": "esbuild node_modules/qrcode/lib/browser.js --bundle --format=esm --platform=browser --outfile=site/js/vendor/qrcode.mjs",
    "site:seed-showcase": "node worker/scripts/seed-showcase-status-plate.mjs",
    "site:seed-showcase-live-object": "node worker/scripts/seed-showcase-live-object.mjs",
    "site:seed-showcase-lost-item": "node worker/scripts/seed-showcase-lost-item.mjs"
  },
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.8.0",
    "@scure/base": "^1.2.6",
    "canonicalize": "^2.1.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "4.47.0"
  },
  "engines": {
    "node": ">=20.18.1"
  }
}
