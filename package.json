{
  "name": "humanity-llc",
  "private": true,
  "description": "Humanity Commons  -  static site (Pages) + reference resolver (Worker)",
  "scripts": {
    "build": "node -e \"const fs=require('fs'); fs.accessSync('site/index.html'); fs.accessSync('site/404.html'); console.log('Static site ready: site/')\"",
    "site:build-meta": "node worker/scripts/generate-build-meta.mjs",
    "worker:build-meta": "node worker/scripts/generate-worker-build-meta.mjs",
    "deploy": "npm run site:build-meta && wrangler pages deploy site --project-name=humanity-llc",
    "pages:deploy": "npm run site:build-meta && wrangler pages deploy site --project-name=humanity-llc",
    "pages:dev": "wrangler pages dev site",
    "worker:dev": "wrangler dev --config worker/wrangler.toml",
    "worker:bundle-scan": "tsx worker/scripts/bundle-scan-assets.ts",
    "worker:deploy": "npm run worker:build-meta && npm run worker:bundle-scan && wrangler deploy --config worker/wrangler.toml",
    "worker:d1:create": "wrangler d1 create humanity-resolver --config worker/wrangler.toml",
    "worker:migrate:local": "wrangler d1 migrations apply humanity-resolver --local --config worker/wrangler.toml",
    "worker:migrate:remote": "wrangler d1 migrations apply humanity-resolver --remote --config worker/wrangler.toml",
    "worker:fixtures": "tsx worker/scripts/generate-fixtures.ts",
    "worker:test": "vitest run",
    "worker:test:device": "vitest run worker/tests/device",
    "worker:test:card-disabled-since-visit": "vitest run worker/tests/wallet-network.test.ts worker/tests/device-wallet-network-confirmed.test.ts worker/tests/device-wallet-network-truth.test.ts worker/tests/card-disabled-since-visit-regression.test.ts worker/tests/card-disabled-since-visit-approaches.test.ts worker/tests/device-hub-frontend-pipeline.test.ts worker/tests/device-hub-search-core.test.ts",
    "worker:test:steward-billing": "vitest run worker/tests/billing-lifecycle.test.ts worker/tests/billing-webhook.test.ts worker/tests/stripe-webhook-verify.test.ts worker/tests/steward-hosted.test.ts",
    "worker:test:steward-entitlements": "vitest run worker/tests/device-steward-entitlements-core.test.ts worker/tests/device-steward-entitlements.test.ts worker/tests/device-steward-session-core.test.ts worker/tests/device-live-control-poll-budget-core.test.ts worker/tests/device-live-control-poll-scheduler.test.ts worker/tests/device-wallet-scale-core.test.ts worker/tests/device-live-control-sw-core.test.ts worker/tests/device-steward-quota-core.test.ts",
    "worker:test:steward-push": "vitest run worker/tests/device-steward-push-core.test.ts worker/tests/steward-push-sse.test.ts worker/tests/steward-push-notify.test.ts worker/tests/device-live-control-sw-core.test.ts",
    "worker:test:steward-ops": "vitest run worker/tests/steward-ops.test.ts worker/tests/steward-ops-thresholds.test.ts",
    "worker:test:steward-hosted": "npm run worker:test:steward-entitlements && npm run worker:test:steward-push && npm run worker:test:steward-billing && npm run worker:test:steward-ops",
    "worker:test:hosted-free-tier": "vitest run worker/tests/device-live-control-poll-scheduler.test.ts worker/tests/device-live-control-round-robin.test.ts worker/tests/device-live-control-poll-budget-core.test.ts worker/tests/device-live-control-poll-leader-core.test.ts worker/tests/device-live-control-sw-core.test.ts worker/tests/device-hub-visible-rows-core.test.ts worker/tests/device-wallet-scale-core.test.ts worker/tests/device-hub-network-tools-core.test.ts worker/tests/device-steward-entitlements-core.test.ts worker/tests/device-steward-entitlements.test.ts worker/tests/conditional-json.test.ts",
    "verify:hosted-g0": "npm run worker:test:hosted-free-tier && npm run worker:test:steward-hosted",
    "hosted:rollout:verify-path": "node worker/scripts/hosted-rollout-verify-path.mjs",
    "hosted:stripe-return-url": "node worker/scripts/hosted-stripe-checkout-return.mjs",
    "hosted:rollout:step1": "node worker/scripts/hosted-rollout-step1.mjs",
    "hosted:rollout:step2": "node worker/scripts/hosted-rollout-step2.mjs",
    "hosted:rollout:step3": "node worker/scripts/hosted-rollout-step3a.mjs",
    "hosted:rollout:step3a": "node worker/scripts/hosted-rollout-step3a.mjs",
    "hosted:rollout:step3b": "node worker/scripts/hosted-rollout-step3b.mjs",
    "hosted:rollout:step4": "node worker/scripts/hosted-rollout-step4.mjs",
    "hosted:rollout:step4a": "node worker/scripts/hosted-rollout-step4a.mjs",
    "hosted:rollout:step4b": "node worker/scripts/hosted-rollout-step4b.mjs",
    "hosted:rollout:post-deploy-smoke": "node worker/scripts/hosted-rollout-post-deploy-smoke.mjs",
    "hosted:rollout:step5": "node worker/scripts/hosted-rollout-step5.mjs",
    "hosted:rollout:step5a": "node worker/scripts/hosted-rollout-step5a.mjs",
    "hosted:rollout:step6": "node worker/scripts/hosted-rollout-step6.mjs",
    "worker:check-steward-ops": "tsx worker/scripts/check-steward-ops-thresholds.ts",
    "e2e:hosted-tier": "playwright test e2e/hosted-tier-budget.spec.ts",
    "e2e:hosted-tier-push": "playwright test e2e/hosted-tier-push.spec.ts",
    "e2e:steward-hosted": "npm run e2e:hosted-tier && npm run e2e:hosted-tier-push",
    "worker:test:ui-color-scheme": "vitest run worker/tests/ui-color-scheme-popover-guard.test.ts",
    "worker:test:created-setup-hash": "vitest run worker/tests/created-setup-hash.test.ts",
    "worker:test:scan-live-check-arrive": "vitest run worker/tests/scan-live-check-arrive-core.test.ts",
    "worker:test:scan-actor-band": "vitest run worker/tests/scan-actor-band-core.test.ts",
    "worker:test:ai-explain": "vitest run worker/tests/ai-explain-core.test.ts worker/tests/ai-explain-snapshot.test.ts",
    "worker:test:ai-draft": "vitest run worker/tests/ai-draft-core.test.ts worker/tests/ai-draft-manifesto.test.ts",
    "worker:test:qr-branding": "vitest run worker/tests/scan-qr-branding.test.ts worker/tests/qr-render-contract.test.ts worker/tests/qr-print-sticker.test.ts",
    "worker:test:scan-page-dot": "vitest run worker/tests/scan-page-dot-core.test.ts worker/tests/scan-page-dot-glance-core.test.ts worker/tests/scan-page-dot-contract.test.ts worker/tests/device-dot-state.test.ts",
    "worker:test:watch": "vitest",
    "e2e": "playwright test",
    "device-shell:e2e": "node worker/scripts/device-shell-e2e-verify.mjs",
    "device-shell:e2e:signoff": "node worker/scripts/device-shell-e2e-verify.mjs --signoff",
    "e2e:device-hub-large-wallet": "playwright test e2e/device-hub-large-wallet-summary.spec.ts",
    "e2e:card-disabled-since-visit": "playwright test e2e/device-os-wallet.spec.ts e2e/device-inbox.spec.ts",
    "e2e:created-control": "playwright test e2e/created-control.spec.ts",
    "e2e:install": "playwright install chromium webkit",
    "e2e:safari": "playwright test e2e/safari-shell-scroll.spec.ts e2e/scan-cross-tab-banner-webkit.spec.ts",
    "e2e:scan-page-dot": "playwright test e2e/scan-page-dot.spec.ts",
    "e2e:scan-hero-visual": "playwright test e2e/scan-hero-visual.spec.ts",
    "e2e:scan-hero-visual:webkit": "playwright test e2e/scan-hero-visual.spec.ts --project=webkit --project=iphone-13-pro",
    "e2e:shell-emphasis-card": "playwright test e2e/shell-emphasis-card-delivery.spec.ts",
    "e2e:keys-custody": "playwright test e2e/device-os-wallet.spec.ts -g \"keys custody\" e2e/keys-custody-emphasis-webkit.spec.ts",
    "e2e:keys-custody:webkit": "playwright test e2e/keys-custody-emphasis-webkit.spec.ts --project=webkit --project=iphone-13-pro",
    "worker:test:keys-custody": "vitest run worker/tests/device-keys-custody-html.test.ts worker/tests/device-keys-custody-core.test.ts worker/tests/device-emphasis-card-html.test.ts",
    "worker:test:pwa-install": "vitest run worker/tests/pwa-install-metadata.test.ts worker/tests/pwa-install-ux.test.ts",
    "worker:test:lazy-shell": "vitest run worker/tests/device-status-lazy-inbox.test.ts worker/tests/device-status-lazy-notifications.test.ts worker/tests/device-status-shell-modules.test.ts",
    "site:generate-scan-e2e-fixture": "tsx worker/scripts/generate-scan-e2e-fixture.ts",
    "site:vendor-qr": "esbuild node_modules/qrcode/lib/browser.js --bundle --format=esm --platform=browser --outfile=site/js/vendor/qrcode.mjs",
    "site:seed-showcase": "node worker/scripts/seed-showcase-status-plate.mjs",
    "site:seed-showcase-live-object": "node worker/scripts/seed-showcase-live-object.mjs",
    "site:seed-showcase-lost-item": "node worker/scripts/seed-showcase-lost-item.mjs",
    "site:refresh-showcase": "node worker/scripts/refresh-showcase-streams.mjs",
    "site:verify-showcase": "node worker/scripts/verify-showcase-resolver.mjs",
    "site:aggregate-pilot-summaries": "node worker/scripts/aggregate-pilot-summaries.mjs",
    "site:verify-positioning-exit": "vitest run worker/tests/manifesto-showcase-exit.test.ts worker/tests/site-showcase-data.test.ts worker/tests/scan-m5-showcase-paths.test.ts worker/tests/seed-showcase-core.test.ts worker/tests/pilot-summary-aggregate.test.ts worker/tests/status-plate-loop-scorecard.test.ts worker/tests/lost-item-relay-loop-scorecard.test.ts",
    "worker:test:manifesto-showcase-exit": "vitest run worker/tests/manifesto-showcase-exit.test.ts worker/tests/site-showcase-data.test.ts worker/tests/scan-m5-showcase-paths.test.ts",
    "worker:test:merch-funnel": "vitest run worker/tests/merch-funnel.test.ts worker/tests/merch-funnel-core.test.ts worker/tests/shop-customize-core.test.ts worker/tests/shop-config-personalize.test.ts worker/tests/shopify-orders-webhook.test.ts worker/tests/merch-funnel-paid-mint-path.test.ts worker/tests/print-order-mint-submit.test.ts worker/tests/wrangler-merch-routes.test.ts",
    "worker:test:merch-print-qa": "vitest run worker/tests/merch-print-artifact-scan-qa.test.ts worker/tests/merch-qr-lifecycle.test.ts",
    "merch-funnel:verify-config": "node worker/scripts/verify-merch-funnel-config.mjs",
    "merch-funnel:verify-exit": "node worker/scripts/verify-merch-funnel-exit.mjs",
    "merch-funnel:verify-exit:fast": "node worker/scripts/verify-merch-funnel-exit.mjs -- --skip-e2e",
    "e2e:merch-funnel": "playwright test e2e/merch-funnel-customize.spec.ts e2e/merch-funnel-checkout.spec.ts"
  },
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.8.0",
    "@scure/base": "^1.2.6",
    "canonicalize": "^2.1.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "4.47.0"
  },
  "engines": {
    "node": ">=20.18.1"
  }
}
