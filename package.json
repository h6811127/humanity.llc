{
  "name": "humanity-llc",
  "private": true,
  "description": "Humanity Commons  -  static site (Pages) + reference resolver (Worker)",
  "scripts": {
    "build": "node -e \"require('fs').accessSync('site/index.html'); console.log('Static site ready: site/')\"",
    "deploy": "wrangler pages deploy site --project-name=humanity-llc",
    "pages:deploy": "wrangler pages deploy site --project-name=humanity-llc",
    "pages:dev": "wrangler pages dev site",
    "worker:dev": "wrangler dev --config worker/wrangler.toml",
    "worker:bundle-scan": "tsx worker/scripts/bundle-scan-assets.ts",
    "worker:deploy": "npm run worker:bundle-scan && wrangler deploy --config worker/wrangler.toml",
    "worker:d1:create": "wrangler d1 create humanity-resolver --config worker/wrangler.toml",
    "worker:migrate:local": "wrangler d1 migrations apply humanity-resolver --local --config worker/wrangler.toml",
    "worker:migrate:remote": "wrangler d1 migrations apply humanity-resolver --remote --config worker/wrangler.toml",
    "worker:fixtures": "tsx worker/scripts/generate-fixtures.ts",
    "worker:test": "vitest run",
    "worker:test:watch": "vitest",
    "site:vendor-qr": "esbuild node_modules/qrcode/lib/browser.js --bundle --format=esm --platform=browser --outfile=site/js/vendor/qrcode.mjs",
    "site:seed-showcase": "node worker/scripts/seed-showcase-status-plate.mjs"
  },
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.8.0",
    "@scure/base": "^1.2.6",
    "canonicalize": "^2.1.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "4.47.0"
  },
  "engines": {
    "node": ">=20.18.1"
  }
}
