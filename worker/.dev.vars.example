# Copy to worker/.dev.vars for local worker:dev (gitignored).
# Production: wrangler secret put OPERATOR_AUDIT_TOKEN --config worker/wrangler.toml

OPERATOR_AUDIT_TOKEN=dev-only-change-me

# Cedar Rapids city game local scan template (worker:dev only — prod stays wrangler.toml "0")
# CITY_GAME_ENABLED=1

# Allow game-contribute before season window dates (local B5 / E5 only — never set in production)
# CITY_GAME_LOCAL_PLAY_OPEN=1

# Local scan HTML (:8787) + Pages static JS (:8788). Required when wrangler simulates humanity.llc routes.
# SCAN_RESOLVER_ORIGIN=http://127.0.0.1:8787
# SCAN_PAGES_JS_ORIGIN=http://127.0.0.1:8788

# Merch / Printify catalog lookup (npm run printify:lookup-blueprint)
# PRINTIFY_API_TOKEN=
# PRINTIFY_SHOP_ID=
