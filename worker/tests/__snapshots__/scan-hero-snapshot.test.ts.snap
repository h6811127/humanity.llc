exports[`scan hero HTML snapshots > live object manifesto-first hero 1`] = `"<article class="scan-hero scan-status-panel scan-safety-header" id="scan-safety-header" aria-label="Live check" data-profile-id="PROFILE" data-qr-id="QR"> <header class="scan-hero-head"> <div class="scan-hero-host"><span class="pass-dot" aria-hidden="true"></span><span>humanity.llc</span></div> <div class="scan-safety-strip scan-safety-strip--live" role="status"> <span class="scan-safety-strip-icon" aria-hidden="true"></span> <span class="scan-safety-strip-label">Active</span> </div> </header> <div class="scan-hero-body"> <h1 class="scan-hero-title">Neighborhood tool library · Closed for inventory until Tuesday</h1> <p class="scan-hero-steward">Controlled by @river_example · Valid until May 16, 2027, 12:00 PM</p> </div> <p class="scan-hero-limit" role="note">This QR resolves to a Humanity Card. It does not prove the person holding this item is the card owner.</p> <ul class="scan-safety-chips scan-hero-details"><li>Revocable</li><li>Issued May 16, 2026</li><li>On Humanity network</li></ul> <p class="scan-safety-first-seen" id="scan-safety-first-seen" hidden></p> <p class="scan-hero-foot">Scan shows live object state.</p> <details class="scan-hero-qr-details"> <summary class="scan-hero-qr-summary">QR on this page</summary> <div class="scan-hero-qr pass-qr scan-status-qr" id="pass-qr-slot" data-scan-url="SCAN_URL"><div class="hc-qr-frame pass-qr-svg" role="img" aria-label="QR code for this Humanity live object scan link"><svg><!-- qr --></svg></div><p class="pass-credential-code mono" aria-label="Credential code for print verification">HC-XXXX-XXXX</p></div> </details> </article>"`;

