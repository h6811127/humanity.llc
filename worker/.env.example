# Copy to repo root as .env (gitignored) or export in your shell before deploy.
# Do NOT commit real tokens.
#
# Create token: Cloudflare Dashboard → My Profile → API Tokens → Create Token
# Template: "Edit Cloudflare Workers" (or custom: Account.Workers Scripts + D1)

CLOUDFLARE_API_TOKEN=

