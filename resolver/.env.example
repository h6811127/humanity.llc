# Tech Spec v0.5 §11.2 — copy to `resolver/.env` (local) or server `/opt/resolver/.env` (§11.1).
# For production, switch DATABASE_PATH / LOG_FILE / PUBLIC_BASE_URL to the values in the comments.

PORT=3000
DATABASE_PATH=./data/profiles.sqlite
PUBLIC_BASE_URL=http://127.0.0.1:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# §11.2 — reserved for future structured app logging (MVP access log uses LOG_FILE / §8.2).
LOG_LEVEL=info

CONSTITUTION_LINK=https://humanity.llc/constitution
GOVERNANCE_LINK=https://humanity.llc/governance

# §8.2 — append-only access log (timestamp, method, path, status, anonymized IP).
LOG_FILE=./data/access.log
# LOG_ENABLED=0

# --- Production (§3.1, §11.2) — uncomment and adjust when deploying ---
# DATABASE_PATH=/var/data/profiles.sqlite
# PUBLIC_BASE_URL=https://resolver.humanity.llc
# LOG_FILE=/var/log/humanity-resolver/access.log
