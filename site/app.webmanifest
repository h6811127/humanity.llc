{
  "id": "/",
  "name": "humanity.llc",
  "short_name": "Humanity",
  "description": "Create, save, verify, and control Humanity live cards from this device.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "background_color": "#ffffff",
  "theme_color": "#ffffff",
