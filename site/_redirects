# Cloudflare Pages  -  use directory index files (same pattern as /created/).
# Do not rewrite /create → create.html (Pages 308-strips .html and causes a redirect loop).
# Unknown paths: site/404.html (HTTP 404). Disable SPA fallback in Pages project settings.

/create  /create/  301
# Product detail SPA — use detail.html (not index.html) so Pages does not re-match the splat and loop.
/shop/products/*  /shop/products/detail.html  200
